# member-mfe environment variables
# These are read by webpack (via DefinePlugin) at build / dev-server start time.
# There is no dotenv loader; either export these in your shell before running
# npm scripts, or rely on the built-in defaults shown below.

# Base URL of the kitchensink JAX-RS API consumed by the remote.
# Default: http://localhost:8080/kitchensink/rest
MFE_REST_BASE_URL=http://localhost:8080/kitchensink/rest

# Port the standalone dev server (and the remoteEntry.js origin) listens on.
# Default: 5001
MFE_PORT=5001
