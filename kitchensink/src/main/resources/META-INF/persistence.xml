<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.0"
   xmlns="https://jakarta.ee/xml/ns/persistence"
   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
   xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
      https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">
   <!-- Net32 augmentation: PostgreSQL replacing H2 -->
   <persistence-unit name="primary">
      <jta-data-source>java:jboss/datasources/KitchensinkPostgreDS</jta-data-source>
      <class>org.jboss.as.quickstarts.kitchensink.model.Member</class>
      <class>org.jboss.as.quickstarts.kitchensink.model.Product</class>
      <class>org.jboss.as.quickstarts.kitchensink.model.Vendor</class>
      <class>org.jboss.as.quickstarts.kitchensink.model.VendorInventory</class>
      <class>org.jboss.as.quickstarts.kitchensink.model.VendorInventoryId</class>
      <class>org.jboss.as.quickstarts.kitchensink.model.Order</class>
      <class>org.jboss.as.quickstarts.kitchensink.model.OrderItem</class>
      <class>org.jboss.as.quickstarts.kitchensink.model.ShippingZone</class>
      <class>org.jboss.as.quickstarts.kitchensink.model.DiscountAudit</class>
      <class>org.jboss.as.quickstarts.kitchensink.model.OrderDraftItem</class>
      <properties>
         <property name="hibernate.hbm2ddl.auto" value="validate"/>
         <property name="hibernate.dialect" value="org.hibernate.dialect.PostgreSQLDialect"/>
         <property name="jboss.entity.manager.factory.jndi.name" value="java:jboss/kitchensinkEntityManagerFactory"/>
      </properties>
   </persistence-unit>
</persistence>
